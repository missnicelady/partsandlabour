<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>parts & labour</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=VT323&family=Courier+Prime:wght@400;700&display=swap');

* { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --pink: #f4a7c3;
  --pink-light: #fde8f2;
  --pink-dark: #c2607e;
  --lavender: #c9b8f0;
  --lav-light: #ede8fc;
  --lav-dark: #7c5cbf;
  --text: #2a1a2e;
  --text-muted: #7a5a7e;
  --border: #e8c4dc;
  --bg: #fff9fd;
}

body {
  font-family: 'Courier Prime', monospace;
  background: var(--bg);
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-transform: lowercase;
  overflow: hidden;
  position: relative;
  padding-bottom: 60px;
}

.stars {
  position: fixed; inset: 0; pointer-events: none; z-index: 0;
}
.star {
  position: absolute; border-radius: 50%;
  animation: twinkle var(--d) ease-in-out infinite alternate;
  opacity: 0.4;
}
@keyframes twinkle {
  from { opacity: 0.15; transform: scale(0.8); }
  to   { opacity: 0.6;  transform: scale(1.2); }
}

.site-title {
  font-family: 'VT323', monospace;
  font-size: clamp(3.5rem, 12vw, 6.5rem);
  color: var(--text);
  letter-spacing: 3px;
  text-align: center;
  position: relative; z-index: 1;
  line-height: 1;
}
.site-title .amp { color: var(--pink-dark); }
.secret-link {
  font-family: 'VT323', monospace;
  font-size: clamp(1.4rem, 4vw, 2rem);
  letter-spacing: 2px;
  color: var(--pink-dark);
  cursor: pointer;
  position: relative; z-index: 1;
  margin-top: 1rem;
  transition: opacity 0.15s;
}
.secret-link:hover { opacity: 0.6; }
  cursor: pointer;
  transition: color 0.15s;
}
.word:hover { color: var(--pink-dark); }
.word.lav:hover { color: var(--lav-dark); }

.scene-wrap {
  position: relative; z-index: 1;
  width: min(500px, 96vw);
  display: flex; flex-direction: column; align-items: center;
  gap: 16px;
}

.cards-row {
  display: flex; gap: 16px; width: 100%; justify-content: center;
  flex-wrap: nowrap;
}

.horo-card {
  flex: 1; min-width: 0;
  border: 1.5px solid var(--border);
  border-radius: 16px;
  padding: 1.25rem 1rem 1rem;
  cursor: pointer;
  transition: transform 0.2s, border-color 0.2s;
  display: flex; flex-direction: column; gap: 10px;
  text-decoration: none;
}
.horo-card:hover { transform: translateY(-5px); }
.horo-card.pink-card { background: var(--pink-light); border-color: var(--pink); }
.horo-card.pink-card:hover { border-color: var(--pink-dark); }
.horo-card.lav-card  { background: var(--lav-light);  border-color: var(--lavender); }
.horo-card.lav-card:hover  { border-color: var(--lav-dark); }

.horo-glyph {
  font-family: 'VT323', monospace;
  font-size: 2.6rem; line-height: 1;
  text-align: center;
  display: block;
}
.pink-card .horo-glyph { color: var(--pink-dark); }
.lav-card  .horo-glyph { color: var(--lav-dark); }

.horo-sign {
  font-family: 'VT323', monospace; font-size: 1.3rem;
  letter-spacing: 2px; text-align: center;
  color: var(--text);
}

.horo-divider {
  height: 1px; background: var(--border); width: 100%;
}

.horo-reading {
  font-size: 11.5px; line-height: 1.5;
  color: var(--text-muted); text-align: left;
}

.horo-tag {
  font-size: 9px; letter-spacing: 2px; text-transform: uppercase;
  padding: 3px 9px; border-radius: 20px; display: inline-block;
  align-self: flex-start;
}
.pink-card .horo-tag { background: var(--pink); color: var(--pink-dark); border: 1px solid var(--pink-dark); }
.lav-card  .horo-tag { background: var(--lavender); color: var(--lav-dark); border: 1px solid var(--lav-dark); }

.horo-footer {
  font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase;
  color: var(--text-muted); text-align: center; margin-top: auto;
}

.name-row {
  display: flex; justify-content: space-between;
  width: 100%;
}
.avatar-name {
  font-family: 'VT323', monospace; font-size: 1.8rem;
  color: var(--text); letter-spacing: 1px; text-align: center;
  cursor: pointer; transition: color 0.15s; flex: 1;
}
.avatar-name:hover { color: var(--pink-dark); }
.avatar-name.lav:hover { color: var(--lav-dark); }

/* player bar */
#player-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--bg);
  border-top: 2px solid var(--pink);
  padding: 0 1rem;
  height: 54px;
  display: flex; align-items: center; gap: 12px;
  z-index: 100;
}
.player-logo {
  font-family: 'VT323', monospace; font-size: 1.3rem;
  color: var(--pink-dark); white-space: nowrap; letter-spacing: 1px;
}
.player-logo span { color: var(--text-muted); font-size: 1rem; }
.play-btn {
  width: 32px; height: 32px; border-radius: 50%;
  border: 1.5px solid var(--pink-dark);
  background: var(--pink-light); color: var(--pink-dark);
  font-size: 13px; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: background 0.15s;
}
.play-btn:hover { background: var(--pink); }
.player-info { display: flex; flex-direction: column; gap: 1px; overflow: hidden; flex: 1; }
.player-station {
  font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--text); white-space: nowrap;
}
.player-ticker { font-size: 10px; color: var(--text-muted); white-space: nowrap; overflow: hidden; }
.ticker-inner { display: inline-block; animation: ticker 18s linear infinite; }
@keyframes ticker {
  0% { transform: translateX(100%); }
  100% { transform: translateX(-100%); }
}
.player-vis { display: flex; align-items: flex-end; gap: 2px; height: 18px; flex-shrink: 0; }
.bar { width: 3px; border-radius: 2px; background: var(--pink-dark); opacity: 0.3; }
.bar.active { opacity: 1; }
.bar:nth-child(1) { animation: b1 0.8s ease-in-out infinite alternate; }
.bar:nth-child(2) { animation: b2 0.6s ease-in-out infinite alternate; }
.bar:nth-child(3) { animation: b3 1s ease-in-out infinite alternate; }
.bar:nth-child(4) { animation: b4 0.7s ease-in-out infinite alternate; }
.bar:nth-child(5) { animation: b5 0.9s ease-in-out infinite alternate; }
@keyframes b1 { from { height: 4px; } to { height: 14px; } }
@keyframes b2 { from { height: 8px; } to { height: 18px; } }
@keyframes b3 { from { height: 3px; } to { height: 12px; } }
@keyframes b4 { from { height: 6px; } to { height: 16px; } }
@keyframes b5 { from { height: 5px; } to { height: 10px; } }
.bars-paused .bar { animation-play-state: paused !important; }
.vol-wrap { display: flex; align-items: center; gap: 6px; flex-shrink: 0; }
.vol-icon { font-size: 13px; color: var(--text-muted); }
input[type=range].vol-slider { width: 60px; accent-color: var(--pink-dark); }
@media (max-width: 480px) { .vol-wrap { display: none; } }

#overlay {
  position: fixed; inset: 0;
  background: var(--pink-light);
  z-index: 999; opacity: 0; pointer-events: none;
  transition: opacity 0.5s;
  display: flex; align-items: center; justify-content: center;
}
#overlay.show { opacity: 1; pointer-events: all; }
.overlay-text {
  font-family: 'VT323', monospace; font-size: 2.5rem;
  color: var(--pink-dark); letter-spacing: 4px;
}
</style>
</head>
<body>

<div class="stars" id="stars"></div>

<div class="site-title">
  <span class="word lav" onclick="handleClick('parts')">parts</span>
  <span class="amp">&</span>
  <span class="word" onclick="handleClick('labour')">labour</span>
</div>
<div class="secret-link" onclick="handleClick('binksinlio')">&#10084;binksinlio&#10084;</div>



<div id="overlay">
  <div class="overlay-text">loading...</div>
</div>

<div id="player-bar">
  <div class="player-logo">kcrw <span>✦</span></div>
  <button class="play-btn" id="playBtn">▶</button>
  <div class="player-info">
    <div class="player-station">89.9 fm — santa monica</div>
    <div class="player-ticker">
      <span class="ticker-inner">click play to stream kcrw live &nbsp;&nbsp;&nbsp;✦&nbsp;&nbsp;&nbsp; music discovery radio from santa monica, ca &nbsp;&nbsp;&nbsp;✦&nbsp;&nbsp;&nbsp; independent public radio</span>
    </div>
  </div>
  <div class="player-vis bars-paused" id="vis">
    <div class="bar"></div><div class="bar"></div><div class="bar"></div>
    <div class="bar"></div><div class="bar"></div>
  </div>
  <div class="vol-wrap">
    <span class="vol-icon">♪</span>
    <input type="range" class="vol-slider" id="vol" min="0" max="1" step="0.05" value="0.8">
  </div>
</div>

<audio id="kcrwAudio" preload="none">
  <source src="https://kcrw.streamguys1.com/kcrw_192k_mp3_e24_internet_radio" type="audio/mpeg">
</audio>

<script>
  const starsEl = document.getElementById('stars');
  for (let i = 0; i < 38; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random() * 5 + 2;
    s.style.cssText = `width:${size}px;height:${size}px;top:${Math.random()*100}%;left:${Math.random()*100}%;--d:${(Math.random()*2+1.5).toFixed(1)}s;background:${Math.random()>0.5?'#f4a7c3':'#c9b8f0'};animation-delay:${(Math.random()*2).toFixed(1)}s;`;
    starsEl.appendChild(s);
  }

  function handleClick(name) {
    const dest = { labour: 'labour.html', binksinlio: 'binksinlio.html' }[name];
    if (dest) {
      const ov = document.getElementById('overlay');
      ov.classList.add('show');
      setTimeout(() => { window.location.href = dest; }, 900);
    }
  }

  

  const audio = document.getElementById('kcrwAudio');
  const playBtn = document.getElementById('playBtn');
  const vis = document.getElementById('vis');
  const volSlider = document.getElementById('vol');
  let playing = false;
  audio.volume = 0.8;

  playBtn.addEventListener('click', () => {
    if (!playing) {
      audio.play();
      playBtn.textContent = '■';
      vis.classList.remove('bars-paused');
      playing = true;
    } else {
      audio.pause();
      audio.src = audio.src;
      playBtn.textContent = '▶';
      vis.classList.add('bars-paused');
      playing = false;
    }
  });

  volSlider.addEventListener('input', () => { audio.volume = volSlider.value; });
</script>
</body>
</html>
